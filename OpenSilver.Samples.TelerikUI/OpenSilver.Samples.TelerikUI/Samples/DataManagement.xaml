<UserControl
    x:Class="OpenSilver.Samples.TelerikUI.Samples.DataManagement"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:local="clr-namespace:OpenSilver.Samples.TelerikUI">

    <StackPanel>
        <TextBlock Text="DataManagement" Style="{StaticResource PageHeader_Style}"/>
        <local:RadGridView_Demo HorizontalAlignment="Left"/>
        <ItemsControl>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <controls:StaggeredPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.Items>
                    <local:RadTreeListView_Demo HorizontalAlignment="Center"/>
                    <local:RadTreeView_Demo HorizontalAlignment="Center"/>
                    <local:RadListBox_Demo HorizontalAlignment="Center"/>
                    <local:RadMap_Demo HorizontalAlignment="Center"/>
            </ItemsControl.Items>
        </ItemsControl>
    </StackPanel>
</UserControl>
