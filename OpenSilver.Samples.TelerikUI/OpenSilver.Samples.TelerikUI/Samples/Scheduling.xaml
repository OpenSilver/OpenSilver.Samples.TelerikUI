<UserControl
    x:Class="OpenSilver.Samples.TelerikUI.Samples.Scheduling"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:local="clr-namespace:OpenSilver.Samples.TelerikUI">

    <StackPanel>
        <TextBlock Text="Scheduling" Style="{StaticResource PageHeader_Style}"/>
        <ItemsControl>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <controls:StaggeredPanel DesiredColumnWidth="760"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.Items>
                <local:RadScheduleView_Demo HorizontalAlignment="Center"/>
                <local:RadGanttView_Demo HorizontalAlignment="Center"/>
                <local:RadCalendar_Demo HorizontalAlignment="Center"/>
            </ItemsControl.Items>
        </ItemsControl>
    </StackPanel>
</UserControl>
